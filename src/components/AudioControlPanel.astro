---
import AudioPlayer from './AudioPlayer.astro';
import ScrollToTop from './ScrollToTop.astro';

interface Props {
  audioSrc?: string;
  audioTitle?: string;
}

const { audioSrc, audioTitle } = Astro.props;
---

<div class="fixed bottom-12 right-4 z-50 flex items-center gap-3">
  {audioSrc && audioTitle && <AudioPlayer src={audioSrc} title={audioTitle} />}
  <ScrollToTop />
</div>