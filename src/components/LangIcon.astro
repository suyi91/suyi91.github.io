---
const currentPath = Astro.url.pathname
const isZh = currentPath.startsWith('/zh')
const switchHref = isZh
  ? (currentPath.replace(/^\/zh/, '') || '/')
  : '/zh' + currentPath
const switchLabel = isZh ? 'EN' : '中'
const targetLang = isZh ? 'en' : 'zh'
---

<a
  id="lang-btn"
  href={switchHref}
  class="header-btn select-none"
  title="Switch language"
  aria-label={isZh ? 'Switch to English' : '切换到中文'}
  data-target-lang={targetLang}
>
  {switchLabel}
</a>

<script>
  document.querySelector('#lang-btn')?.addEventListener('click', (e) => {
    const lang = (e.currentTarget as HTMLElement).dataset.targetLang
    if (lang) localStorage.setItem('lang', lang)
  })
</script>
