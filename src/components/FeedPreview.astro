---
import FeedPostDate from "./FeedPostDate.astro";
const {post, index, lang = 'en'} = Astro.props;
const {data, body, slug} = post;
import {useTranslations, type Lang} from '../i18n/utils'
const t = useTranslations(lang as Lang)
const cleanSlug = slug.replace(/^(en|zh)\//, '')
const prefix = lang === 'zh' ? '/zh/feed/' : '/feed/'
---

<div>
  <p
    class="break-all first-letter tracking-wide first-letter:font-semibold first-letter:text-2xl"
  >
    {
      body.length > 140
        ? body.replace(/^#+/gm, "")
              .replace(/!?\[.*?\]\(.*?\)/g, "")
              .substring(0, 140) + "..."
        : body.replace(/^#+/gm, "")
              .replace(/!?\[.*?\]\(.*?\)/g, "")
    }
  </p>
  <div class="flex items-center justify-between mt-2 text-sm">
    <FeedPostDate date={data.date} index={index}/>
    <a class="hover:text-skin-active text-sm border rounded py-1 px-2" href={`${prefix}${cleanSlug}`}>{t('home.readMore')}</a>
  </div>
</div>
