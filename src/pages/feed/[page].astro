---
import {site} from "../../consts";
import IndexPage from '../../layouts/IndexPage.astro'
import Pagination from "src/components/Pagination.astro";
import { sortPostsByDate } from "src/utils/sortPostsByDate";
import { getCollectionByName } from "../../utils/getCollectionByName";
import FeedPreview from "../../components/FeedPreview.astro";
export async function getStaticPaths({ paginate }) {
  let posts = await getCollectionByName("feed", 'en');
  posts = sortPostsByDate(posts);
  return paginate(posts, { pageSize: site.feedPageSize });
}

const { page } = Astro.props;
---

<IndexPage frontmatter={{title: 'Feed'}} lang="en">
  {page.data.map((post, index) => <FeedPreview post={post} index={index} lang="en" />)}
  <Pagination
    currentPage={page.currentPage}
    totalPage={page.lastPage}
    url={page.slug}
    prefixUrl="/feed/"
  />
</IndexPage>
